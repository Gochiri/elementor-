# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (NUNCA exponer en el cliente) — usado por rutas API / worker
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Fase 1+ (worker) — no necesarios para Fase 0
# ANTHROPIC_API_KEY=
# SERANKING_API_KEY=
# FIGMA_TOKEN=
# WP_BASE_URL=
# WP_APP_PASSWORD=
