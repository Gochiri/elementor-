# Worker — credenciales de servidor (NUNCA en el cliente)
# Supabase: usa la SERVICE ROLE key (bypassa RLS). Project Settings → API.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — para generar el copy (paso ②)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cada cuántos ms busca pasos en cola
POLL_INTERVAL_MS=5000

# SE Ranking Data API (paso ① — opcional). Sin esta key, ① genera keywords candidatas
# sin métricas y queda en 'revisión'. Con key, las enriquece con volumen/dificultad/intención.
# Crear key en el Dashboard de la API de SE Ranking (plan Data API, de pago, 100 créditos/petición).
# SERANKING_API_KEY=
# SERANKING_SOURCE=es
